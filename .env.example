# Public Supabase config used by the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin login/session config. Keep private in Vercel/local env.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_DB_SECRET=

# Server-only Supabase key. Never expose with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Public WhatsApp number for checkout handoff, digits only or international format.
NEXT_PUBLIC_WHATSAPP=
